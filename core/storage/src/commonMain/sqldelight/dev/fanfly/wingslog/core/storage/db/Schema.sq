-- Generic key-value-by-id store for proto-encoded entities.
-- See docs/storage_r1_design.md §4.
--
import dev.fanfly.wingslog.core.storage.CollectionKind;
import dev.fanfly.wingslog.core.storage.blob.RemoteState;

-- `collection` is widened to the CollectionKind sealed type via a SQLDelight
-- ColumnAdapter (see CollectionKind.kt) so neither application code nor SQL
-- ever sees a raw collection-name string in normal use.
-- `updated_at` is device wall-clock at write time, used for UI display and
-- as a tiebreaker for push order — NEVER for sync ordering. Sync ordering uses
-- `remote_updated_at`, which is the Firestore server timestamp (§5.3).

CREATE TABLE entity (
  collection         TEXT    AS CollectionKind NOT NULL,
  scope_path         TEXT    NOT NULL,
  id                 TEXT    NOT NULL,
  payload            BLOB    NOT NULL,
  payload_schema     TEXT    NOT NULL,
  updated_at         INTEGER NOT NULL,
  remote_updated_at  INTEGER,
  dirty              INTEGER AS kotlin.Boolean NOT NULL DEFAULT 0,
  deleted            INTEGER AS kotlin.Boolean NOT NULL DEFAULT 0,
  -- Who wrote this revision (design §7.5). Stamped on our own writes, carried down from the sync
  -- envelope on pull. Null for rows written before this existed.
  writer_uid         TEXT,
  PRIMARY KEY (collection, scope_path, id)
);

CREATE INDEX entity_scope_idx ON entity(collection, scope_path);
CREATE INDEX entity_dirty_idx ON entity(collection, scope_path, updated_at);

CREATE TABLE sync_cursor (
  uid               TEXT    NOT NULL,
  collection        TEXT    AS CollectionKind NOT NULL,
  scope_path        TEXT    NOT NULL,
  hydrated          INTEGER AS kotlin.Boolean NOT NULL DEFAULT 0,
  last_seen_remote  INTEGER,
  failed_attempts   INTEGER NOT NULL DEFAULT 0,
  last_attempt_at   INTEGER,
  PRIMARY KEY (uid, collection, scope_path)
);

CREATE TABLE sync_config (
  uid   TEXT NOT NULL,
  key   TEXT NOT NULL,
  value TEXT NOT NULL,
  PRIMARY KEY (uid, key)
);

-- Entity queries.

selectAll:
SELECT id, payload, updated_at, writer_uid
FROM entity
WHERE collection = :collection AND scope_path = :scope AND deleted = 0
ORDER BY updated_at DESC;

selectOne:
SELECT id, payload, updated_at, writer_uid
FROM entity
WHERE collection = :collection AND scope_path = :scope AND id = :id AND deleted = 0;

upsert:
INSERT OR REPLACE INTO entity(
  collection, scope_path, id, payload, payload_schema,
  updated_at, remote_updated_at, dirty, deleted, writer_uid
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Read the full sync state of one row. Used by the pull listener's comparator,
-- which needs `dirty` and `remote_updated_at` to decide whether to apply a
-- remote write. Tombstoned rows (deleted = 1) are intentionally returned —
-- the comparator may need to revive a row remotely re-created at the same id.
selectOneForSync:
SELECT collection, scope_path, id, payload, updated_at, remote_updated_at, dirty, deleted
FROM entity
WHERE collection = :collection AND scope_path = :scope AND id = :id;

selectDirty:
SELECT collection, scope_path, id, payload, updated_at, deleted
FROM entity
WHERE dirty = 1
ORDER BY updated_at ASC
LIMIT :limit;

-- Scoped variants — used by [PushWorker] so that one user's dirty rows aren't pushed under
-- another user's auth (which would PERMISSION_DENIED). The prefix is the user's scope-path
-- prefix, e.g. "/users/{uid}/%".
selectDirtyInScope:
SELECT collection, scope_path, id, payload, updated_at, deleted
FROM entity
WHERE dirty = 1 AND scope_path LIKE :scopePrefix
ORDER BY updated_at ASC
LIMIT :limit;

countDirtyInScope:
SELECT COUNT(*) FROM entity WHERE dirty = 1 AND scope_path LIKE :scopePrefix;

clearDirty:
UPDATE entity SET dirty = 0
WHERE collection = ? AND scope_path = ? AND id = ?;

setRemoteUpdatedAt:
UPDATE entity SET remote_updated_at = ?
WHERE collection = ? AND scope_path = ? AND id = ?;

countDirty:
SELECT COUNT(*) FROM entity WHERE dirty = 1;

gcTombstones:
DELETE FROM entity
WHERE deleted = 1 AND dirty = 0 AND updated_at < :cutoffMs;

-- Shared-scope purge (revoked/left/deleted shares). Hard deletes, not tombstones — this is another
-- account's data the member was only granted a view of, so it was never ours to tombstone.

selectScopeAndIdForCollection:
SELECT scope_path, id FROM entity WHERE collection = :collection;

deleteEntitiesInScopePrefix:
DELETE FROM entity WHERE scope_path LIKE :scopePrefix;

deleteEntity:
DELETE FROM entity WHERE collection = :collection AND scope_path = :scope AND id = :id;

-- Sync cursor queries.

selectCursor:
SELECT * FROM sync_cursor
WHERE uid = ? AND collection = ? AND scope_path = ?;

upsertCursor:
INSERT OR REPLACE INTO sync_cursor(
  uid, collection, scope_path, hydrated, last_seen_remote,
  failed_attempts, last_attempt_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

deleteCursorsInScopePrefix:
DELETE FROM sync_cursor WHERE scope_path LIKE :scopePrefix;

-- Sync config queries.

selectConfig:
SELECT value FROM sync_config WHERE uid = ? AND key = ?;

upsertConfig:
INSERT OR REPLACE INTO sync_config(uid, key, value) VALUES (?, ?, ?);

-- Attachment binary index. See docs/storage_r2_design.md §4.
-- This table is device-local — never synced to Firestore. Each row mirrors an Attachment
-- proto reference held in some entity payload. The proto itself is the cross-device source
-- of truth (id, sha256, size, mime); blob_object adds the device-local fields needed to
-- track upload/download state and locate the bytes on disk.
CREATE TABLE blob_object (
  id               TEXT    NOT NULL PRIMARY KEY,
  scope_path       TEXT    NOT NULL,
  relative_path    TEXT    NOT NULL,
  content_type     TEXT,
  size_bytes       INTEGER NOT NULL,
  sha256           TEXT    NOT NULL,
  remote_state     TEXT    AS RemoteState NOT NULL,
  remote_path      TEXT,
  upload_attempts  INTEGER NOT NULL DEFAULT 0,
  last_attempt_at  INTEGER,
  updated_at       INTEGER NOT NULL,
  deleted          INTEGER AS kotlin.Boolean NOT NULL DEFAULT 0,
  resume_url       TEXT
);

CREATE INDEX blob_state_idx ON blob_object(scope_path, remote_state);
CREATE INDEX blob_pending_idx ON blob_object(remote_state, last_attempt_at);

-- Blob queries.

upsertBlob:
INSERT OR REPLACE INTO blob_object(
  id, scope_path, relative_path, content_type, size_bytes, sha256,
  remote_state, remote_path, upload_attempts, last_attempt_at, updated_at, deleted
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectBlobById:
SELECT * FROM blob_object WHERE id = ?;

selectAllBlobsInScope:
SELECT * FROM blob_object WHERE scope_path = ? ORDER BY updated_at DESC;

selectPendingUploads:
SELECT * FROM blob_object
WHERE deleted = 0
  AND remote_state IN ('LOCAL_ONLY', 'UPLOADING')
  AND scope_path LIKE :scopePrefix
ORDER BY updated_at ASC
LIMIT :limit;

selectPendingDownloads:
SELECT * FROM blob_object
WHERE deleted = 0
  AND remote_state = 'REMOTE_ONLY'
  AND scope_path LIKE :scopePrefix
ORDER BY updated_at ASC
LIMIT :limit;

selectBlobTombstones:
SELECT * FROM blob_object WHERE deleted = 1 ORDER BY updated_at ASC LIMIT :limit;

setBlobRemoteState:
UPDATE blob_object
SET remote_state = ?, remote_path = ?, last_attempt_at = ?, upload_attempts = ?
WHERE id = ?;

markBlobDeleted:
UPDATE blob_object SET deleted = 1, updated_at = ? WHERE id = ?;

hardDeleteBlob:
DELETE FROM blob_object WHERE id = ?;

-- Sum of size_bytes for all non-deleted blobs in the user's scope. Used by QuotaChecker
-- (PR 3) and the Settings → Storage usage display. Returns 0 when there are no rows.
sumBlobSizeInScope:
SELECT COALESCE(SUM(size_bytes), 0) AS used FROM blob_object
WHERE scope_path = :scope AND deleted = 0;

selectBlobsForScope:
SELECT * FROM blob_object
WHERE scope_path = :scopePath AND deleted = 0;

selectBlobsForScopePrefix:
SELECT * FROM blob_object
WHERE scope_path LIKE :scopePrefix AND deleted = 0;

resetUploadAttempts:
UPDATE blob_object
SET upload_attempts = 0
WHERE id = :id;

deleteBlobsForUser:
DELETE FROM blob_object
WHERE scope_path LIKE :scopePrefix;

setResumeUrl:
UPDATE blob_object SET resume_url = :resumeUrl WHERE id = :id;

clearResumeUrl:
UPDATE blob_object SET resume_url = NULL WHERE id = :id;

-- Wipe queries used by the integrity-check recovery flow (PRD §10).
-- sync_config is intentionally excluded so user preferences survive the wipe.

wipeAllEntities:
DELETE FROM entity;

wipeAllSyncCursors:
DELETE FROM sync_cursor;

wipeAllBlobObjects:
DELETE FROM blob_object;

-- Per-user wipe queries used on sign-out so that on next sign-in the sync engine
-- re-hydrates from Firestore and the BlobIndexReconciler rebuilds blob_object rows.

deleteEntitiesForUser:
DELETE FROM entity WHERE scope_path LIKE :scopePrefix;

deleteSyncCursorsForUser:
DELETE FROM sync_cursor WHERE uid = :uid;

-- Account-merge re-keying (guest → account upgrade, see docs/account_upgrade_design.html §6).
-- Moves every local row owned by one uid into another uid's scope by rewriting the
-- "/users/{uid}/" prefix. Entities are marked dirty with remote_updated_at cleared so the sync
-- engine re-uploads them under the destination account; blobs are reset to LOCAL_ONLY so they
-- re-upload. Callers also drop both uids' sync cursors so the destination re-hydrates.

-- :remainderStart is the 1-based index just past the old "/users/{fromUid}/" prefix; substr returns
-- the path tail, which is re-prefixed with :newPrefix. It is bound as text and SQLite coerces it to
-- an integer for substr (SQLDelight types a bare substr offset parameter as String).
reassignEntities:
UPDATE entity
SET scope_path = :newPrefix || substr(scope_path, :remainderStart),
    dirty = 1,
    remote_updated_at = NULL
WHERE scope_path LIKE :oldPrefixLike;

reassignBlobs:
UPDATE blob_object
SET scope_path = :newPrefix || substr(scope_path, :remainderStart),
    remote_state = 'LOCAL_ONLY',
    remote_path = NULL,
    upload_attempts = 0
WHERE scope_path LIKE :oldPrefixLike;
