<resources>
  <!-- Manage Access screen -->
  <string name="manage_access_title">Manage Access</string>
  <string name="manage_access_empty_title">No shared access</string>
  <string name="manage_access_empty_desc">Invite a co-owner or technician to share this aircraft.</string>
  <!-- "Owner" is only ever the hosting owner. Anyone you invite, promote, or who redeems an invite
       is by definition not the host — you are — so every other owner-role label reads "co-owner". -->
  <string name="manage_access_role_owner">Owner</string>
  <string name="manage_access_role_co_owner">Co-owner</string>
  <string name="manage_access_role_technician">Technician</string>
  <string name="manage_access_badge_you">You</string>
  <string name="manage_access_unnamed_member">Unnamed member</string>
  <string name="manage_access_member_actions">Member actions</string>
  <string name="manage_access_make_owner">Make co-owner</string>
  <string name="manage_access_make_technician">Make technician</string>
  <string name="manage_access_revoke">Remove access</string>
  <string name="manage_access_leave">Leave shared aircraft</string>
  <string name="manage_access_invite">Invite</string>
  <!-- Revoke confirmation (PRD D2/D3). Revoking is server-enforced and immediate, and it destroys
       any edits the member made offline and had not yet synced — the one data-loss window in the
       design. The owner is told that before they do it, not after. -->
  <string name="revoke_confirm_title">Remove %1$s?</string>
  <string name="revoke_confirm_body">They lose access to this aircraft immediately, and their copy of its records is removed from their devices.

If they made changes while offline that have not synced yet, those changes are lost.</string>
  <string name="revoke_confirm_action">Remove access</string>
  <!-- Leave confirmation. Same data-loss caveat, from the member's own side. -->
  <string name="leave_confirm_title">Leave this aircraft?</string>
  <string name="leave_confirm_body">It is removed from your fleet and its records are deleted from your devices. Any changes you made offline that have not synced yet are lost.

The owner can invite you again.</string>
  <string name="leave_confirm_action">Leave</string>
  <!-- Invite sheet -->
  <string name="invite_title">Invite to aircraft</string>
  <string name="invite_role_label">Role</string>
  <string name="invite_role_owner">Co-owner</string>
  <string name="invite_role_technician">Technician</string>
  <string name="invite_create">Create invite link</string>
  <string name="invite_note">Single-use link, expires in 7 days.</string>
  <string name="invite_scan_hint">Scan this code, or share the link.</string>
  <string name="invite_share">Share link</string>
  <string name="invite_copy">Copy link</string>
  <string name="invite_copied">Link copied</string>
  <string name="invite_pending_title">Pending invites</string>
  <string name="invite_cancel">Cancel invite</string>
  <string name="invite_qr_desc">Invite QR code</string>
  <string name="invite_new">New invite</string>
  <string name="invite_link_unavailable">This link was created on another device, so it can't be shown here. Cancel it and create a new one to share again.</string>
  <!-- Redeem confirmation -->
  <string name="redeem_confirm_title">Aircraft invitation</string>
  <string name="redeem_confirm_body">You've been invited to share an aircraft. Accept to add it to your fleet.</string>
  <string name="redeem_needs_signin_title">Sign in to accept</string>
  <string name="redeem_needs_signin_body">Sign in with your account to accept this invitation. It will still be here when you're signed in.</string>
  <string name="redeem_success_title">You're in</string>
  <string name="redeem_success_body">You now have access as %1$s. The aircraft will appear in your fleet shortly.</string>
  <string name="redeem_already_member_title">Already a member</string>
  <string name="redeem_already_member_body">You already have access to this aircraft.</string>
  <string name="redeem_failed_title">Invite unavailable</string>
  <string name="redeem_failed_body">This invite is no longer valid. Ask the owner for a new one.</string>
  <string name="redeem_role_owner">a co-owner</string>
  <string name="redeem_role_technician">a technician</string>
  <!-- PRD E2: sharing is a cloud feature. With Cloud Sync off there is nothing to share into and
       nothing to receive from, so management is disabled and says why rather than failing on tap. -->
  <string name="sharing_sync_off_title">Cloud Sync is off</string>
  <string name="sharing_sync_off_body">Sharing needs Cloud Sync. Turn it on in Settings to invite people or manage access. Aircraft already shared with you stay readable, but will not update.</string>
</resources>
