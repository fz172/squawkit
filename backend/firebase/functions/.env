EXPORT_DELIVERY_PROVIDER=resend
EXPORT_DELIVERY_FROM_EMAIL=support@mail.fanfly.dev
# Cooldown (in seconds) before the same export can be re-sent by email. Default 86400 = 24 hours.
# Set to 0 to remove the resend throttle while dogfooding export email; restore to 86400 for GA.
EXPORT_DELIVERY_RESEND_COOLDOWN_SECONDS=0

# --- Storage sweep (#159). All four are REQUIRED — the sweep refuses to deploy without them. ---
# How often it runs.
STORAGE_SWEEP_SCHEDULE="every 24 hours"
# How long a tombstone survives. Correctness, not cost: purge before every device has synced the
# delete and the record comes back from the dead. Keep in step with the client's local TombstoneGc.
TOMBSTONE_RETENTION_DAYS=30
# How old an UNREFERENCED blob must be before it can be collected. Never applies to a blob a live
# record still references — those are kept forever, at any age.
ORPHAN_BLOB_GRACE_DAYS=7
# ARMED: the sweep really deletes. Set to "true" to put it back in rehearsal (report, delete nothing).
STORAGE_SWEEP_DRY_RUN=false
