{
  "name": "wingslog-firebase-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "npm run generate:proto && tsc",
    "generate:proto": "mkdir -p src/generated/proto && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --proto_path=../../../core/model/src/commonMain/proto --ts_proto_out=src/generated/proto --ts_proto_opt=esModuleInterop=true,outputServices=none,useOptionals=none,forceLong=number ../../../core/model/src/commonMain/proto/rpc/request_export_delivery/request_export_delivery.proto ../../../core/model/src/commonMain/proto/sharing/shared_aircraft_ref.proto",
    "watch": "tsc --watch",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "firebase emulators:exec --only firestore,storage --project demo-squawkit \"$(command -v node) node_modules/vitest/vitest.mjs run\""
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.5.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.15.0",
    "firebase-functions-test": "^3.5.0",
    "grpc-tools": "^1.13.0",
    "ts-proto": "^2.7.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
