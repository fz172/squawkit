# Placeholder values only. Keep real secrets in Firebase Functions secret/env management
# or in untracked local files such as .env.local during development.

EXPORT_DELIVERY_PROVIDER=resend
EXPORT_DELIVERY_FROM_EMAIL=export@fanfly.dev
# Cooldown (in seconds) before the same export can be re-sent by email. Default 86400 = 24 hours.
EXPORT_DELIVERY_RESEND_COOLDOWN_SECONDS=86400

# --- Storage sweep (#159) ---
# How often the sweep runs (App Engine cron or unix-cron). Changing it re-provisions the Scheduler job.
STORAGE_SWEEP_SCHEDULE="every 24 hours"
# Tombstone retention. A CORRECTNESS constraint, not a cost knob: purge before every device has seen
# the tombstone and the deleted record comes back. Matches the client's local TombstoneGc.
TOMBSTONE_RETENTION_DAYS=30
# How old an unreferenced blob must be before it can be collected. Records and blobs travel in
# separate queues, so a fresh photo can land before the log that references it.
ORPHAN_BLOB_GRACE_DAYS=7
# Report what WOULD be deleted, delete nothing. Set to "false" to ARM it — a deliberate act.
STORAGE_SWEEP_DRY_RUN=true
