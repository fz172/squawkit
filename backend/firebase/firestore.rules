rules_version = '2';

// Source of truth for Firestore security rules. Deployed by the
// "Deploy Firestore Rules" GitHub Action (or `firebase deploy --only firestore:rules`) and tested
// via the emulator suite in functions/test. Do NOT hand-edit in the Firebase console — a deploy
// overwrites it.
//
// Aircraft sharing (docs/sharing): an aircraft and its records physically stay under the hosting
// owner's tree (users/{host}/aircraft/{acId}/...). Other accounts are granted access by the
// aircraft_shares/{acId} ACL, which these rules consult with a single get(). Field names are
// camelCase to match the client envelope and the functions schema (sharingModels.ts).

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Sharing helpers -----------------------------------------------------------------------

    // The caller's role on a shared aircraft, or null/error if they aren't in the ACL.
    // A single get() per shared-scope request (billed as one read, cached per request).
    function shareRole(acId) {
      return get(/databases/$(database)/documents/aircraft_shares/$(acId))
        .data.memberRoles[request.auth.uid];
    }
    function isShareOwner(acId) {
      return shareRole(acId) == 'owner';
    }
    function isShareMember(acId) {
      return shareRole(acId) in ['owner', 'technician'];
    }

    // Authorship attestation: a client write must stamp its own uid as writerUid (or omit it —
    // legacy/unattested docs). Makes "who wrote this revision" tamper-evident. See docs/sharing §7.5.
    function writerIsSelf() {
      return !('writerUid' in request.resource.data)
        || request.resource.data.writerUid == request.auth.uid;
    }

    // Only the four synced per-aircraft kinds may be written into a shared aircraft's subtree,
    // so a member can't create arbitrary subcollections in the host's tree.
    function isSharedAircraftKind(kind) {
      return kind in ['maintenance_log', 'maintenance_task', 'maintenance_overview', 'squawk'];
    }

    // --- Default deny --------------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }

    // --- User trees ----------------------------------------------------------------------------

    match /users/{userId} {

      // Own tree: unchanged — a signed-in user has full access to their own subtree.
      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }

      // Shared aircraft document. Members may GET it (they know the id from their ref) but not
      // LIST the host's aircraft collection — that keeps the host's OTHER aircraft private and
      // forces the doc-level sync path (docs/sharing §5.2). Only owners may edit the aircraft.
      match /aircraft/{acId} {
        allow get: if request.auth.uid == userId || isShareMember(acId);
        // Co-owners may edit the aircraft, but only the hosting owner may delete it — deleting an
        // aircraft tears down the whole share (§3.3), so it must not be a peer-owner capability.
        // The tombstone is a write with deleted=true; restricting that to the own-tree branch
        // leaves deletion to the host. PRD §4: "Delete the aircraft — hosting owner only."
        allow write: if request.auth.uid == userId
          || (isShareOwner(acId) && writerIsSelf() && request.resource.data.deleted != true);

        // Nested maintenance data: any member may read; any member may write the known kinds,
        // attested. (The host's own writes are already granted by the own-tree rule above.)
        match /{kind}/{docId} {
          allow read: if request.auth.uid == userId || isShareMember(acId);
          allow write: if request.auth.uid == userId
            || (isSharedAircraftKind(kind) && isShareMember(acId) && writerIsSelf());
        }
      }
    }

    // --- Share ACL tree (plain-field, rules-readable) ------------------------------------------

    match /aircraft_shares/{acId} {
      // Members see the ACL. memberRoles is function-managed, so no client update/delete.
      //
      // The own-aircraft check is deliberately fenced to `resource == null` — the case where the ACL
      // doc does not exist yet and there is therefore NOTHING TO LEAK. It exists only so the owner
      // can read the empty result and bootstrap the doc before the first invite (§3.1); it must be
      // the left operand, because on a missing doc isShareMember's get() errors and would deny the
      // whole rule before the fallback ran.
      //
      // It must NOT guard a doc that exists. An aircraft id is only unique WITHIN a tree, and every
      // user may write anything into their own tree — so "I have an aircraft with this id" is not a
      // claim to be the host, it is a claim anyone who knows the id can manufacture. That id is in
      // every invite link and is remembered by every ex-member. Guarding a live ACL with it handed
      // them hostUid, the full membership list, and (via members/) certificate numbers. See #202.
      //
      // Once the doc exists, membership is the only key: the host is in memberRoles, so isShareMember
      // covers them too.
      allow get: if (resource == null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/aircraft/$(acId)))
        || isShareMember(acId);
      allow create: if request.resource.data.hostUid == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/aircraft/$(acId));
      allow update, delete: if false; // functions only

      match /members/{memberUid} {
        // Members only. A not-yet-shared aircraft has no ACL, so this denies — and that is correct:
        // there is no roster to read. Manage Access already treats the denial as "no members yet"
        // (AircraftShareState.accessDenied) and still lets the owner invite.
        //
        // No own-aircraft escape hatch here (#202): these docs carry display names, photo URLs and
        // technician mirrors — certificate numbers and expiry dates. Anyone who knew the aircraft id
        // could mint a same-id aircraft in their own tree and read all of it, revoked or not.
        allow read: if isShareMember(acId);
        // A member maintains their own display + technician mirror; role stays immutable from
        // clients (function-managed). Delete is function-only.
        allow update: if request.auth.uid == memberUid
          && request.resource.data.role == resource.data.role;
        // A member may create their OWN member doc, but only with the role the ACL already grants
        // them — so this cannot mint membership or escalate a role, it only backfills the display
        // record. The hosting owner needs this: they never redeem, so no function ever writes their
        // member doc, and without it they'd be absent from the roster (design §7.2).
        allow create: if request.auth.uid == memberUid
          && request.resource.data.role == shareRole(acId);
        allow delete: if false;
      }

      match /invites/{tokenHash} {
        // Owner reads the invite list (Manage Access). Denied before the ACL exists, which is fine:
        // there are no invites yet, and the client degrades to an empty list.
        //
        // No own-aircraft escape hatch (#202) — pending invites are live credentials.
        allow read: if isShareOwner(acId);
        allow create, update: if isShareOwner(acId); // create/cancel invites
        allow delete: if false;
      }
    }
  }
}
