rules_version = '2';

// Source of truth for Firestore security rules. Deployed by the
// "Deploy Firestore Rules" GitHub Action (or `firebase deploy --only firestore:rules`) and tested
// via the emulator suite in functions/test. Do NOT hand-edit in the Firebase console — a deploy
// overwrites it.
//
// Aircraft sharing (docs/sharing): an aircraft and its records physically stay under the hosting
// owner's tree (users/{host}/aircraft/{acId}/...). Other accounts are granted access by the
// aircraft_shares/{acId} ACL, which these rules consult with a single get(). Field names are
// camelCase to match the client envelope and the functions schema (sharingModels.ts).

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Sharing helpers -----------------------------------------------------------------------

    // The caller's role on a shared aircraft, or null/error if they aren't in the ACL.
    // A single get() per shared-scope request (billed as one read, cached per request).
    //
    // [hostUid] is ALWAYS taken from the path of the resource being accessed — never from a field,
    // and never from anything the caller supplies. That is the whole security property (#204).
    //
    // The ACL used to live at aircraft_shares/{acId}: one global slot for an id that is only unique
    // WITHIN a tree. Anyone could create that slot for an id they knew, honestly declaring themselves
    // hostUid — no lie required — and the lookup, keyed by acId alone, would then consult THEIR doc
    // to authorize access to SOMEONE ELSE'S aircraft. Namespacing by host means a doc a caller can
    // create only ever governs the caller's own tree.
    function shareRole(hostUid, acId) {
      return get(/databases/$(database)/documents/aircraft_shares/$(hostUid)/aircraft/$(acId))
        .data.memberRoles[request.auth.uid];
    }
    function isShareOwner(hostUid, acId) {
      return shareRole(hostUid, acId) == 'owner';
    }
    function isShareMember(hostUid, acId) {
      return shareRole(hostUid, acId) in ['owner', 'technician'];
    }

    // Authorship attestation: a client write must stamp its own uid as writerUid (or omit it —
    // legacy/unattested docs). Makes "who wrote this revision" tamper-evident. See docs/sharing §7.5.
    function writerIsSelf() {
      return !('writerUid' in request.resource.data)
        || request.resource.data.writerUid == request.auth.uid;
    }

    // Only the four synced per-aircraft kinds may be written into a shared aircraft's subtree,
    // so a member can't create arbitrary subcollections in the host's tree.
    function isSharedAircraftKind(kind) {
      return kind in ['maintenance_log', 'maintenance_task', 'maintenance_overview', 'squawk'];
    }

    // --- Default deny --------------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }

    // --- User trees ----------------------------------------------------------------------------

    match /users/{userId} {

      // Own tree: unchanged — a signed-in user has full access to their own subtree.
      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }

      // Shared aircraft document. Members may GET it (they know the id from their ref) but not
      // LIST the host's aircraft collection — that keeps the host's OTHER aircraft private and
      // forces the doc-level sync path (docs/sharing §5.2). Only owners may edit the aircraft.
      match /aircraft/{acId} {
        // userId is the tree being accessed — that is the host, by definition. Unspoofable: it is
        // the path the caller asked for, not a claim they made.
        allow get: if request.auth.uid == userId || isShareMember(userId, acId);
        // Co-owners may edit the aircraft, but only the hosting owner may delete it — deleting an
        // aircraft tears down the whole share (§3.3), so it must not be a peer-owner capability.
        // The tombstone is a write with deleted=true; restricting that to the own-tree branch
        // leaves deletion to the host. PRD §4: "Delete the aircraft — hosting owner only."
        allow write: if request.auth.uid == userId
          || (isShareOwner(userId, acId) && writerIsSelf() && request.resource.data.deleted != true);

        // Nested maintenance data: any member may read; any member may write the known kinds,
        // attested. (The host's own writes are already granted by the own-tree rule above.)
        match /{kind}/{docId} {
          allow read: if request.auth.uid == userId || isShareMember(userId, acId);
          allow write: if request.auth.uid == userId
            || (isSharedAircraftKind(kind) && isShareMember(userId, acId) && writerIsSelf());
        }
      }
    }

    // --- Subscription entitlement / SquawkIt Pro -----------------------------------------------

    // Account-level entitlement, server-authoritative. It lives OUTSIDE the user tree on purpose:
    // the broad users/{uid}/{document=**} rule grants the owner write, and Firestore rules are
    // additive — so a doc under the user tree would be client-forgeable, i.e. a paywall bypass. Here
    // the owner may READ their own entitlement; only the Admin SDK (the billing pipeline and the
    // storage-usage sweep) writes it. See docs/subscription/subscription_design.html §3.
    match /subscriptions/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false; // functions only
    }

    // --- Pairing-code invites (#164) -----------------------------------------------------------

    // The code IS the secret: the document holds the aircraft id, the host uid, and the role, keyed
    // by the code itself. No client may read or write it — only the callables, as admin.
    //
    // That is the point of the whole mechanism. The invitee holds an opaque code instead of an
    // aircraft id, so a non-member never learns an id to fabricate a same-id aircraft against
    // (#202/#204). Granting clients so much as a read here would hand back exactly what the code was
    // introduced to withhold.
    match /invite_codes/{code} {
      allow read, write: if false; // functions only
    }

    // Failed-attempt counters behind the rate limiter. A client that could read these would learn
    // how much guessing budget it has left; one that could write them could reset it.
    match /invite_attempts/{uid} {
      allow read, write: if false; // functions only
    }

    // --- Share ACL tree (plain-field, rules-readable) ------------------------------------------

    // Keyed by HOST, then aircraft (#204). The {hostUid} segment is pinned to the caller's own uid
    // on create, and request.auth.uid comes from a signed token — so a caller can only ever mint a
    // share over their OWN tree. A share they create governs their own aircraft and nothing else.
    //
    // The old key was aircraft_shares/{acId}: a single global slot for an id that is unique only
    // within a tree. Spoofing hostUid was never needed — an attacker created that one slot honestly
    // declaring themselves host, and the lookup (keyed on acId alone) then consulted THEIR doc to
    // authorize access to the VICTIM's aircraft. Reachable in practice: deleting a shared aircraft
    // removes its ACL while leaving the records behind, so an ex-member could re-claim the id and
    // read (and write) the deleted aircraft. See #204.
    match /aircraft_shares/{hostUid}/aircraft/{acId} {
      // Membership is the only key. Nothing else — no "I have an aircraft with this id", which is a
      // claim anyone who knew the id could manufacture (#202), and which no longer buys even the
      // bootstrap read now that createAircraftShareInvite bootstraps the ACL server-side (#164).
      //
      // On a not-yet-shared aircraft there is no ACL, so this denies. Correct: there is nothing to
      // read. Manage Access already treats the denial as "no members yet"
      // (AircraftShareState.accessDenied) and still offers Invite, because the owner's role comes
      // from the local refs rather than from this doc.
      allow get: if isShareMember(hostUid, acId);

      // Function-only since #164: createAircraftShareInvite bootstraps the ACL as admin, so no client
      // ever needs to. That retires the last forgeable check — the old rule leaned on "I have an
      // aircraft with this id in my tree", which anyone could manufacture. #204 made that harmless by
      // namespacing the key; this removes it outright.
      allow create, update, delete: if false; // functions only

      match /members/{memberUid} {
        // Members only — these carry display names, photos, and technician mirrors (certificate
        // numbers and expiry dates). No own-aircraft escape hatch (#202).
        allow read: if isShareMember(hostUid, acId);
        // A member maintains their own display + technician mirror; role stays immutable from
        // clients (function-managed). Delete is function-only.
        allow update: if request.auth.uid == memberUid
          && request.resource.data.role == resource.data.role;
        // A member may create their OWN member doc, but only with the role the ACL already grants
        // them — so this cannot mint membership or escalate a role, it only backfills the display
        // record. The hosting owner needs this: they never redeem, so no function ever writes their
        // member doc, and without it they would be absent from the roster (design §7.2).
        allow create: if request.auth.uid == memberUid
          && request.resource.data.role == shareRole(hostUid, acId);
        allow delete: if false;
      }

      match /invites/{tokenHash} {
        // Owner reads the invite list (Manage Access). Denied before the ACL exists, which is fine:
        // there are no invites yet, and the client degrades to an empty list. Pending invites are
        // live credentials — no own-aircraft escape hatch (#202).
        // Owner-visible record of a pending invite: role and expiry, NOT the code. Reading this
        // list yields nothing redeemable (#164). Creation and cancellation are function-only now —
        // both have to touch the invite_codes collection, which clients cannot see.
        allow read: if isShareOwner(hostUid, acId);
        allow write: if false; // functions only
      }
    }

  }
}
